{
	"name": "docs",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"check": "biome check --write",
		"check:types": "tsc --noEmit",
		"check:sdk-drift": "npx tsx .github/actions/sdk-drift-check/check-sdk-drift.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"dev": "vite dev",
		"build": "pnpm diagrams:build && vite build && node scripts/patch-cf.ts",
		"diagrams:build": "pnpm exec mmdc -i diagrams/mpp-flow.mmd -o public/diagrams/mpp-flow.svg -c diagrams/mermaid.config.json && bash scripts/postprocess-svg.sh public/diagrams/mpp-flow.svg",
		"deploy": "wrangler deploy",
		"gen:types": "wrangler types",
		"postinstall": "pnpm gen:types",
		"preview": "vite preview",
		"wrangler:dev": "wrangler dev"
	},
	"dependencies": {
		"dayjs": "^1.11.19",
		"mermaid": "^11.12.2",
		"mpay": "https://pkg.pr.new/wevm/mpay@6c4bdf0",
		"react": "^19",
		"react-dom": "^19",
		"viem": "latest",
		"vocs": "https://pkg.pr.new/wevm/vocs@fe37e87",
		"waku": "^1.0.0-alpha.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.13",
		"@hiogawa/node-loader-cloudflare": "^0.0.2",
		"@mermaid-js/mermaid-cli": "^11.4.2",
		"@types/node": "^22",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-react": "^5",
		"typescript": "^5",
		"vite": "^7",
		"vitest": "^4.0.18",
		"wrangler": "^4.61.1"
	}
}
